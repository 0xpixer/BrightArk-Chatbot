{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:deploy",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" }
  ],
  "functions": {
    "api/chat.ts": {
      "maxDuration": 60
    },
    "api/admin.ts": {
      "maxDuration": 30
    },
    "api/auth/google.ts": {
      "maxDuration": 30
    },
    "api/auth/google-callback.ts": {
      "maxDuration": 30
    },
    "api/public/widget-config.ts": {
      "maxDuration": 10
    }
  }
}
