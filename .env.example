# Copy to ".env.local" and fill in real values (never commit .env.local).

# Required for chat (if not using DB-stored key in admin)
OPENAI_API_KEY=

# Postgres — required for admin portal, saved settings, dialogue logs
# On Vercel: use DATABASE_URL, or the integration may only set POSTGRES_PRISMA_URL / POSTGRES_URL (supported automatically).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# First admin (optional): run once — npx prisma db seed
# SEED_ADMIN_EMAIL=you@company.com
# SEED_ADMIN_PASSWORD=choose-a-strong-password
# SEED_ADMIN_USERNAME=Admin

# Optional
OPENAI_WORKFLOW_ID=
ADMIN_PUBLIC_URL=
GUARDRAILS_OPENAI_API_KEY=
GUARDRAIL_MODEL=gpt-4o-mini
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
